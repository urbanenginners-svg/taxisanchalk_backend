NODE_ENV=development
MONGO_CONNECTION_STRING=mongodb://localhost:27017/school-erp
JWT_SECRET=your_jwt_secret
SENTRY_DSN=your_sentry_dsn
MASTER_KEY=your_master_key

# Optional — Airtel DLT SMS (customer OTP). When AIRTEL_ACTIVE_MODE is not "true", sends are skipped.
# AIRTEL_API_TOKEN=base64_credentials_for_basic_auth
# AIRTEL_ENTITY_ID=
# AIRTEL_CUSTOMER_ID=
# AIRTEL_URL=https://...
# AIRTEL_ACTIVE_MODE=false

# QueueBuster — third-party routes use QUEBUSTER_URL; set QUEBUSTER_PARTNER_URL only if token host differs.
# QUEBUSTER_PARTNER_URL=https://api.queuebuster.co/API/public/v1
QUEBUSTER_URL=https://api.queuebuster.co/API/public/v1
QUEBUSTER_CLIENT_ID=
QUEBUSTER_CLIENT_SECRET=
# Chain id for `thirdparty/{chainId}/fetchProducts` (e.g. 82586). QUEBUSTER_CHAIN_ID is preferred; otherwise QUEBUSTER_THIRD_PARTY_CHAIN_ID.
QUEBUSTER_CHAIN_ID=82586
# QUEBUSTER_THIRD_PARTY_CHAIN_ID=

# ERP2 — base URL (e.g. https://erp2.api.sbzee.com/api/v1 or http://localhost:3600/api/v1)
# ERP2_WEBHOOK=
# ERP2_API_SECRET_KEY=

# AWS SES — franchise emails use AWS_SES_FROM_EMAIL; all other emails use AWS_SES_NOREPLY_EMAIL
# AWS_SES_FROM_EMAIL=partners@sbzee.com
# AWS_SES_NOREPLY_EMAIL=no-reply@sbzee.com

# Daily warehouse inventory CSV report (cron at 1:00 AM)
# INVENTORY_REPORT_RECIPIENT=ware1212122112221@yopmail.com

